{
  "$meta": {
    "name": "Spotify-inspired Design System",
    "source": "https://open.spotify.com/",
    "extractedOn": "2026-06-17",
    "note": "Tokens extracted from the live Spotify Web Player via computed styles. Colors are the Spotify-style dark theme. Brand green is #1ED760 (current) with #1DB954 as the legacy/alt green."
  },
  "colors": {
    "brand": {
      "primary": "#1ED760",
      "primaryHover": "#3BE477",
      "primaryActive": "#1AAF4E",
      "legacyGreen": "#1DB954",
      "accent": "#1ED760",
      "error": "#E22134",
      "success": "#1ED760",
      "warning": "#FFA42B"
    },
    "background": {
      "base": "#121212",
      "default": "#000000",
      "elevated": "#1F1F1F",
      "elevatedHighlight": "#2A2A2A",
      "tinted": "#181818",
      "press": "#333333",
      "overlay": "rgba(0, 0, 0, 0.7)",
      "scrim": "rgba(0, 0, 0, 0.3)"
    },
    "text": {
      "primary": "#FFFFFF",
      "secondary": "#B3B3B3",
      "muted": "#7C7C7C",
      "onBrand": "#000000",
      "onDark": "#FFFFFF",
      "subdued70": "rgba(255, 255, 255, 0.7)"
    },
    "border": {
      "subtle": "rgba(255, 255, 255, 0.1)",
      "default": "#333333",
      "strong": "#535353"
    }
  },
  "typography": {
    "fontFamily": {
      "primary": "\"Spotify Mix\", \"Circular\", \"Helvetica Neue\", Helvetica, Arial, sans-serif",
      "title": "\"Spotify Mix Title\", \"Circular\", \"Helvetica Neue\", Helvetica, Arial, sans-serif",
      "fallback": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif"
    },
    "fontWeights": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "black": 900
    },
    "fontSize": {
      "xs": "11px",
      "sm": "12px",
      "base": "14px",
      "md": "16px",
      "lg": "20px",
      "xl": "24px",
      "2xl": "32px",
      "3xl": "48px",
      "4xl": "72px"
    },
    "lineHeight": {
      "tight": "1.2",
      "base": "1.4",
      "relaxed": "1.6"
    },
    "letterSpacing": {
      "normal": "0",
      "tight": "-0.02em"
    }
  },
  "spacing": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "28px",
    "8": "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px"
  },
  "borderRadius": {
    "none": "0px",
    "xs": "2px",
    "sm": "4px",
    "md": "8px",
    "card": "6px",
    "lg": "16px",
    "pill": "9999px",
    "full": "999px",
    "circle": "50%"
  },
  "shadow": {
    "card": "0 8px 24px rgba(0, 0, 0, 0.5)",
    "raised": "0 4px 12px rgba(0, 0, 0, 0.3)",
    "player": "0 -2px 8px rgba(0, 0, 0, 0.4)"
  },
  "components": {
    "button": {
      "primary": {
        "backgroundColor": "#1ED760",
        "color": "#000000",
        "padding": "8px 32px",
        "borderRadius": "9999px",
        "fontWeight": 700,
        "fontSize": "16px",
        "border": "none",
        "hover": { "backgroundColor": "#3BE477", "transform": "scale(1.04)" }
      },
      "secondary": {
        "backgroundColor": "transparent",
        "color": "#FFFFFF",
        "padding": "8px 32px",
        "borderRadius": "9999px",
        "fontWeight": 700,
        "fontSize": "16px",
        "border": "1px solid #7C7C7C",
        "hover": { "borderColor": "#FFFFFF", "transform": "scale(1.04)" }
      },
      "text": {
        "backgroundColor": "transparent",
        "color": "#B3B3B3",
        "padding": "4px 16px",
        "fontWeight": 700,
        "fontSize": "14px",
        "hover": { "color": "#FFFFFF" }
      },
      "iconCircle": {
        "backgroundColor": "#1F1F1F",
        "color": "#FFFFFF",
        "padding": "12px",
        "borderRadius": "50%"
      },
      "playButton": {
        "backgroundColor": "#1ED760",
        "color": "#000000",
        "borderRadius": "50%",
        "size": "48px",
        "hover": { "backgroundColor": "#3BE477", "transform": "scale(1.06)" }
      }
    },
    "header": {
      "backgroundColor": "#121212",
      "padding": "16px 16px 8px",
      "color": "#B3B3B3"
    },
    "nav": {
      "color": "#B3B3B3",
      "activeColor": "#FFFFFF",
      "fontSize": "16px",
      "fontWeight": 700
    },
    "card": {
      "backgroundColor": "#181818",
      "hoverBackgroundColor": "#282828",
      "borderRadius": "6px",
      "padding": "12px"
    },
    "playerBar": {
      "backgroundColor": "#000000",
      "color": "#FFFFFF",
      "height": "72px"
    },
    "input": {
      "backgroundColor": "#FFFFFF",
      "color": "#121212",
      "borderRadius": "9999px",
      "padding": "12px 16px"
    }
  }
}

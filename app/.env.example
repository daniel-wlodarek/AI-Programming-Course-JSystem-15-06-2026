# Required for server-side OpenRouter calls
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=openai/gpt-5.4-mini
OPENROUTER_VISION_MODEL=openai/gpt-5.4

# Optional OpenRouter attribution headers
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_TITLE=Hardware Service Decision Copilot

# Legacy/direct model variables kept only for course experiments outside this app
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENROUTER_MODEL=openai/gpt-5.4-mini
CONTEXT7_API_KEY=ctx7-your-context7-key-here
PORT=3000
